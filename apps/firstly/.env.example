# Vercel: copy these into Project Settings → Environment Variables (Production / Preview).
# Jazz Cloud — API key from https://dashboard.jazz.tools (or use an email for temporary access).
NEXT_PUBLIC_JAZZ_API_KEY=
# Optional: full WebSocket URL instead of NEXT_PUBLIC_JAZZ_API_KEY (include ?key= for cloud.jazz.tools).
# NEXT_PUBLIC_JAZZ_SYNC_PEER=wss://cloud.jazz.tools/?key=
# Session AI chat (server-only; never expose to the client)
# Which backend to use is set in lib/ai-chat-config.ts (ACTIVE_CHAT_PROVIDER).
# Set only the API key(s) for the provider you choose.
# OpenRouter (OpenAI-compatible): https://openrouter.ai
OPENROUTER_API_KEY=
# Optional overrides (defaults in lib/openrouter-config.ts)
OPENROUTER_CHAT_MODEL=
OPENROUTER_HTTP_REFERER=
# Google Generative AI (AI Studio): https://ai.google.dev — used when ACTIVE_CHAT_PROVIDER is "google"
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional override (default in lib/ai-chat-config.ts: GOOGLE_DEFAULT_CHAT_MODEL)
GOOGLE_GENERATIVE_AI_CHAT_MODEL=
# Direct OpenAI — used when ACTIVE_CHAT_PROVIDER is "openai"
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
