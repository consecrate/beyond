# Vercel: copy into Project Settings → Environment Variables (Production / Preview).
# Jazz Cloud — API key from https://dashboard.jazz.tools (or use an email for temporary access).
NEXT_PUBLIC_JAZZ_API_KEY=
# Optional: full WebSocket URL instead of NEXT_PUBLIC_JAZZ_API_KEY.
# NEXT_PUBLIC_JAZZ_SYNC_PEER=wss://cloud.jazz.tools/?key=

# Upstash Redis — short join codes for live sessions (GET/POST /api/live-sessions).
# Without these, the API falls back to in-memory storage (dev only; not suitable for production).
# Copy the two lines below into apps/playdeck/.env.local for local dev.
# For Vercel: Project → Settings → Environment Variables → add the same keys for Production
# (and Preview if join codes should work on preview deployments). Mark as sensitive. Redeploy after saving.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# UploadThing — slide image uploads (token from https://uploadthing.com/dashboard)
# Base64 JSON per UploadThing: { apiKey, appId, regions }
UPLOADTHING_TOKEN=
